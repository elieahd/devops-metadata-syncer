<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="devops.metadata.syncer.infrastructure.outbound.database.dao.PipelineRunDao">

    <resultMap id="pipelineRunResultMap" type="devops.metadata.syncer.domain.models.PipelineRun">
        <constructor>
            <arg column="success" javaType="_boolean"/>
            <arg column="started_at" javaType="java.time.OffsetDateTime"/>
            <arg column="created_at" javaType="java.time.OffsetDateTime"/>
            <arg column="updated_at" javaType="java.time.OffsetDateTime"/>
            <arg column="duration_seconds" javaType="java.time.Duration"/>
        </constructor>
    </resultMap>

    <select id="findAllByPipelineId" resultMap="pipelineRunResultMap">
        SELECT success,
               started_at,
               created_at,
               updated_at,
               duration_seconds
        FROM pipeline_run
        WHERE pipeline_id = #{pipelineId}
    </select>

    <insert id="insertAll">
        INSERT INTO pipeline_run (pipeline_id, success, started_at, created_at, updated_at, duration_seconds)
        VALUES
        <foreach collection="runs" item="run" separator=",">
            (
            #{pipelineId},
            #{run.success},
            #{run.startedAt},
            #{run.createdAt},
            #{run.updatedAt},
            #{run.duration.seconds}
            )
        </foreach>
    </insert>

    <delete id="deleteAllByRepositoryId">
        DELETE
        FROM pipeline_run
        USING pipeline
        WHERE pipeline.id = pipeline_run.pipeline_id
          AND pipeline.repository_id = #{repositoryId}
    </delete>

</mapper>
